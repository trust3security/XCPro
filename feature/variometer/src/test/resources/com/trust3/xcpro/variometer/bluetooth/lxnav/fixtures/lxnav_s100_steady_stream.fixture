# Sanitized LXNAV S100 steady-state capture.
# LXWP1 serial values use synthetic placeholders like SN0001; any real serial
# was replaced and the checksum was recomputed after substitution.
@session start
100|$LXWP1,S100,SN0001,1.2.3,2.0*40
200|$LXWP0,Y,88.4,654.1,1.12*54
300|$PLXVF,,1.00,0.87,-0.12,-0.25,90.2,244.3*48
400|$PGRMZ,1,2,3*4E
500|$LXWP0,Y,88.4,654.1,1.12*00
@session end
