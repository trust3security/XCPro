    <string name="thermalling_title">Thermalling</string>

    <string name="thermalling_card_automation_title">Thermalling automation</string>
    <string name="thermalling_card_automation_description">
        Automatically switch mode and or zoom when circling starts and stops.
    </string>
    <string name="thermalling_switch_enable_title">Enable thermalling automation</string>
    <string name="thermalling_switch_enable_description">
        Master toggle for auto mode and zoom behavior.
    </string>
    <string name="thermalling_switch_mode_title">Switch to Thermal flight mode</string>
    <string name="thermalling_switch_mode_description">
        When active, change flight mode after enter delay.
    </string>
    <string name="thermalling_switch_zoom_fallback_title">
        Zoom fallback if Thermal mode hidden
    </string>
    <string name="thermalling_switch_zoom_fallback_description">
